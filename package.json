{
  "name": "lubbdubb",
  "version": "0.1.0",
  "private": true,
  "description": "Self-hosted orchestration harness — a cockpit that watches your work inputs, decides what to do, and dispatches AI agents autonomously.",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "node --import tsx --watch src/server/main.ts",
    "start": "node --import tsx src/server/main.ts",
    "test": "node --import tsx --test test/**/*.test.ts",
    "test:coverage": "c8 --config .c8rc.json node --import tsx --test test/**/*.test.ts",
    "smoke": "node --import tsx scripts/smoke.ts",
    "web:dev": "vite --config web/vite.config.ts",
    "web:dev:demo": "vite --config web/vite.config.ts --mode demo",
    "web:build": "vite --config web/vite.config.ts build",
    "web:build:demo": "vite --config web/vite.config.ts build --mode demo --base=/LubbDubb/",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "typecheck:web": "tsc -p web/tsconfig.json --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\" \"web/**/*.{ts,tsx}\" \"scripts/*.ts\" \"*.{json,md}\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"test/**/*.ts\" \"web/**/*.{ts,tsx}\" \"scripts/*.ts\" \"*.{json,md}\"",
    "knip": "knip",
    "audit": "npm audit --audit-level=high",
    "check": "npm run format:check && npm run lint && npm run typecheck && npm run typecheck:web && npm run knip && npm test"
  },
  "dependencies": {
    "@fastify/rate-limit": "^9.1.0",
    "@fastify/static": "^7.0.4",
    "@fastify/websocket": "^10.0.1",
    "@octokit/rest": "^22.0.1",
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/headless": "^6.0.0",
    "@xterm/xterm": "^5.5.0",
    "better-sqlite3": "^11.3.0",
    "fastify": "^4.28.1",
    "nanoid": "^5.0.7",
    "node-pty": "^1.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@eslint/js": "9.18.0",
    "@types/better-sqlite3": "^7.6.11",
    "@types/node": "^22.5.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^4.3.1",
    "c8": "10.1.3",
    "eslint": "9.18.0",
    "eslint-config-prettier": "9.1.0",
    "eslint-plugin-react": "7.37.4",
    "eslint-plugin-react-hooks": "5.1.0",
    "globals": "15.14.0",
    "knip": "5.42.2",
    "prettier": "3.4.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tsx": "^4.19.0",
    "typescript": "^5.5.4",
    "typescript-eslint": "8.20.0",
    "vite": "^5.4.2"
  }
}
