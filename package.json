{
  "name": "lubbdubb",
  "version": "0.1.0",
  "private": true,
  "description": "Self-hosted orchestration harness — a cockpit that watches your work inputs, decides what to do, and dispatches AI agents autonomously.",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "node --import tsx --watch src/server/main.ts",
    "start": "node --import tsx src/server/main.ts",
    "test": "node --import tsx --test test/**/*.test.ts",
    "smoke": "node --import tsx scripts/smoke.ts",
    "web:dev": "vite --config web/vite.config.ts",
    "web:build": "vite --config web/vite.config.ts build",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@fastify/static": "^7.0.4",
    "@fastify/websocket": "^10.0.1",
    "better-sqlite3": "^11.3.0",
    "fastify": "^4.28.1",
    "nanoid": "^5.0.7",
    "node-pty": "^1.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.11",
    "@types/node": "^22.5.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^4.3.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tsx": "^4.19.0",
    "typescript": "^5.5.4",
    "vite": "^5.4.2"
  }
}
